{
  "name": "my-courses",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest --config vitest.config.ts",
    "test:run": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "openapi:types": "openapi-typescript ./src/shared/openapi/schema.yaml -o ./src/shared/generated/openapi-types.ts",
    "openapi:orval": "orval --config ./orval.config.ts",
    "openapi:generate": "npm run openapi:types && npm run openapi:orval"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@hookform/resolvers": "^3.10.0",
    "@react-router/node": "7.15.0",
    "@react-router/serve": "7.15.0",
    "@tanstack/react-query": "^5.62.7",
    "axios": "^1.7.9",
    "bootstrap-icons": "^1.13.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "isbot": "^5.1.36",
    "lucide-react": "^1.14.0",
    "prop-types": "^15.8.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.54.2",
    "react-router": "7.15.0",
    "react-router-dom": "^7.15.0",
    "sass": "^1.99.0",
    "sonner": "^2.0.7",
    "swiper": "^12.1.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.2",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@react-router/dev": "7.15.0",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "msw": "^2.10.5",
    "openapi-typescript": "^7.10.1",
    "orval": "^7.9.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.6"
  }
}
